# Copy this file to ".env" and fill in your values.

# Your Firebase project id (Firestore console → Project settings).
# For local dev against the Firestore emulator, any "demo-*" id works with no
# real credentials at all — e.g. demo-bugsite.
FIREBASE_PROJECT_ID=demo-bugsite

# Local dev: point at the Firestore emulator instead of a real project.
#   firebase emulators:start --only firestore
# Leave unset to talk to the real Firebase project above.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Production: a service account key (Firebase console → Project settings →
# Service accounts → Generate new private key). Not needed when
# FIRESTORE_EMULATOR_HOST is set. Use ONE of:
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}   # paste the whole
#   JSON file as one line — for hosts (e.g. Railway) with no file to point at

# Port the API listens on (the React app calls this).
PORT=4000
