# Copy this file to ".env" and fill in your values.

# Where MongoDB is running. This is the SAME string you paste into
# MongoDB Compass to browse the data.
#   - Local MongoDB Community Server:  mongodb://127.0.0.1:27017
#   - MongoDB Atlas (cloud):           mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGODB_URI=mongodb://127.0.0.1:27017

# Database + collection the products get seeded into.
DB_NAME=bugsite

# Port the API listens on (the React app calls this).
PORT=4000

# Optional: only needed if you hit "querySrv ECONNREFUSED" when connecting to an
# Atlas (mongodb+srv) cluster. Forces Node to use a DNS server that resolves the
# SRV record. Leave unset for a normal local MongoDB.
DNS_SERVER=8.8.8.8
